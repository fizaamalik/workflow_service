APP_ENV=dev

# Async SQLAlchemy URL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/workflow_db

# Downstream services (set to real URLs in your environment)
CORE_SERVICE_URL=http://localhost:8001
ENTITY_SERVICE_URL=http://localhost:8002
NOTIFICATION_SERVICE_URL=http://localhost:8003

# Service-to-service token for Entity Service (if enforced there)
ENTITY_SERVICE_TOKEN=dev-token

# Public key for JWT validation (required at startup). In dev you can use `Authorization: Bearer dev`.
JWT_PUBLIC_KEY=dev-public-key-placeholder
